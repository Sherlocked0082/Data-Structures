#include<bits/stdc++.h>
using namespace std;

int main()
 {
 	int n,q,t,fans=0,ans=0;
 	cin>>n>>q;
 	vector<int> u;
 	vector<int> A;
 	int Q[q][4];
 	// vector<vector<int>> Q;
 	for(int i=0;i<n;i++)
 	{
 		cin>>u[i];
 	}
 	for(int i=0;i<n;i++)
 	{
 		cin>>A[i];
 	}
 	for(int i=0;i<q;i++)
 	{
 		for(int j=0;j<4;j++)
 		{
 			cin>>Q[i][j];
 		}
 	}
 	for(int i=0;i<q;i++)
 	{
 		for(int j=0;j<4;j++)
 		{
			cout<<Q[i][j];
 		}
 		cout<<endl;
 	}

 	for(int k=0;k<q;k++)
 	{
 		t=Q[k][3]-Q[k][2];
 		fans=0;
 		for(int i=Q[k][0];i<Q[k][1];i++)
 		{
 			ans+=u[i]*t+1/2*A[i]*t*t;
 		}
 		fans+=ans;
 		cout<<fans;
 	}


 	return 0;
 }